{
  "name": "dnsmasq-setup",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "semantic-release": "semantic-release",
    "commitizen:init": "commitizen init cz-conventional-changelog && npm uninstall @commitlint/cli @commitlint/config-conventional && npm i @commitlint/cli @commitlint/config-conventional --save-optional",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky install"
  },
  "keywords": [
    "dnsmasq",
    "dns",
    "domain name in docker",
    "codekitten",
    "http proxy"
  ],
  "author": "Mahboob Monna Mohamed",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^18.11.9",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.27.0",
    "eslint-config-prettier": "^8.5.0",
    "husky": "^8.0.2",
    "lint-staged": "^13.0.3",
    "markdownlint": "^0.26.2",
    "markdownlint-cli": "^0.32.2",
    "prettier": "^2.7.1",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.4"
  },
  "dependencies": {
    "commander": "^9.4.1",
    "dockerode": "^3.3.4",
    "listr2": "^5.0.5"
  },
  "lint-staged": {
    "*.{ts, tsx}": [
      "npm run format",
      "eslint --cache --fix .",
      "git add -A"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "optionalDependencies": {
    "@commitlint/cli": "^17.2.0",
    "@commitlint/config-conventional": "^17.2.0"
  }
}
